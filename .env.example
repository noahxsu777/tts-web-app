# Copy this file to .env and fill in your values.

# Port the server listens on (defaults to 8080 if unset)
PORT=8080

# API key from https://hyperbeam.com — required for the shared "Navegador
# virtual" feature. Without it, that feature returns an error but the rest
# of the app (video sync, chat, WebRTC) works fine.
HYPERBEAM_API_KEY=sk_test_qUmKKllge2u4g3vt1Q_3XadDhPtGyWk6w1oCz8hvsVk

# YouTube Data API v3 key (https://console.developers.google.com) — required
# to search YouTube from the video input box. Without it, pasting a direct
# YouTube/video URL still works fine; only the search falls back to an error.
YOUTUBE_API_KEY=
